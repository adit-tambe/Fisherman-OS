# Fisherman OS backend configuration — copy to .env and fill in.

ENVIRONMENT=development
TIMEZONE=Asia/Kolkata

# --- Database ---------------------------------------------------------------
# Local dev (default): SQLite. Production: Supabase Postgres, e.g.
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./fisherman_os.db

# --- WhatsApp (Gupshup BSP) ---------------------------------------------------
# whatsapp_provider: console (dev, logs instead of sending) | gupshup
WHATSAPP_PROVIDER=console
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=FishermanOS
GUPSHUP_SOURCE_NUMBER=          # the bot's WhatsApp number, e.g. 917700012345

# --- LLM responder (Groq) -------------------------------------------------------
# Free-form question answering in en/kok/hi/mr. Leave GROQ_API_KEY empty to
# disable (bot falls back to the static help reply). NEVER commit a real key.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=12
LLM_RATE_LIMIT_PER_HOUR=30

# --- Weather ------------------------------------------------------------------
# weather_provider: auto (INCOIS -> OpenWeatherMap -> synthetic) | incois | openweathermap | synthetic
WEATHER_PROVIDER=auto
INCOIS_RSS_URL=https://tools.incois.gov.in/osf/rss/goa.xml
OPENWEATHER_API_KEY=

# --- Scheduler (IST) ------------------------------------------------------------
ENABLE_SCHEDULER=true
MORNING_FORECAST_HOUR=3
MORNING_FORECAST_MINUTE=30
PRICE_PUSH_HOUR=5
PRICE_PUSH_MINUTE=0
SOS_PING_INTERVAL_MINUTES=5

# --- SOS ---------------------------------------------------------------------
COAST_GUARD_NUMBER=1554

# --- Admin / field-agent API ----------------------------------------------------
ADMIN_API_KEY=change-me

# --- Business -------------------------------------------------------------------
TRIAL_DAYS=30
SUBSCRIPTION_PRICE_INR=99
